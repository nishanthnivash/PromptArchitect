
{
  "entities": {
    "SavedPrompt": {
      "title": "Saved Prompt",
      "description": "A collection of architected prompts saved by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who saved the prompt." },
        "rawThought": { "type": "string", "description": "The original input provided by the user." },
        "detectedIntent": { "type": "string", "description": "The intent detected by the AI." },
        "createdAt": { "type": "string", "format": "date-time" },
        "prompts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "style": { "type": "string" },
              "content": { "type": "string" },
              "isStarred": { "type": "boolean" },
              "scores": {
                "type": "object",
                "properties": {
                  "clarity": { "type": "number" },
                  "clarityReasoning": { "type": "string" },
                  "specificity": { "type": "number" },
                  "specificityReasoning": { "type": "string" },
                  "quality": { "type": "number" },
                  "qualityReasoning": { "type": "string" }
                }
              },
              "reasoning": { "type": "string" }
            }
          }
        }
      },
      "required": ["userId", "rawThought", "prompts", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Developer profile settings.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "roleTagline": { "type": "string" },
        "bio": { "type": "string" },
        "githubUrl": { "type": "string" },
        "linkedinUrl": { "type": "string" },
        "portfolioUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/savedPrompts/{promptId}": {
      "schema": "SavedPrompt",
      "description": "User saved architected prompts."
    },
    "/userProfiles/{userId}": {
      "schema": "UserProfile",
      "description": "User profile and developer card settings."
    }
  }
}
