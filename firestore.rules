rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Saved Prompts ──────────────────────────────────────────────────────────
    // Each user can only read, write, update, and delete their own saved prompts.
    match /savedPrompts/{docId} {
      allow read, delete: if request.auth != null
                          && request.auth.uid == resource.data.userId;

      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId
                    && request.resource.data.keys().hasAll(['userId', 'rawThought', 'detectedIntent', 'prompts', 'createdAt'])
                    && request.resource.data.rawThought is string
                    && request.resource.data.rawThought.size() <= 5000
                    && request.resource.data.prompts is list
                    && request.resource.data.prompts.size() <= 10;

      allow update: if request.auth != null
                    && request.auth.uid == resource.data.userId
                    // Only allow updating 'prompts' field (for star-toggle & regenerate)
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['prompts']);
    }

    // ── User Profiles ──────────────────────────────────────────────────────────
    // Each user can only read and write their own profile document.
    match /userProfiles/{userId} {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow write:  if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.userId == userId
                    && request.resource.data.keys().hasAll(['userId'])
                    && (!('displayName' in request.resource.data) || request.resource.data.displayName is string)
                    && (!('bio' in request.resource.data) || request.resource.data.bio.size() <= 500);
    }

    // ── Deny everything else ───────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
